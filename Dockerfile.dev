# Development environment for myruntime.
# Alternative to Vagrant — runs on any machine with Docker.
#
# IMPORTANT: Building containers inside a Docker container requires --privileged.
# This is fine for development but understand the security implications.
#
# Usage:
#   docker build -f Dockerfile.dev -t myruntime-dev .
#   docker run --privileged -it -v $(pwd):/workspace myruntime-dev
#
# The --privileged flag is needed because myruntime uses:
# - Namespace syscalls (clone, unshare, setns)
# - Cgroup filesystem operations
# - Mount operations (overlay, pivot_root)
# - Device node creation (mknod)
# - iptables for networking

FROM ubuntu:22.04

RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    iptables \
    iproute2 \
    bridge-utils \
    uidmap \
    tree \
    strace \
    && rm -rf /var/lib/apt/lists/*

# Install Go
ARG GO_VERSION=1.22.0
RUN curl -sL "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" | tar -C /usr/local -xzf -
ENV PATH="/usr/local/go/bin:/root/go/bin:${PATH}"

WORKDIR /workspace
COPY go.mod go.sum* ./
RUN go mod download 2>/dev/null || true

# Default: drop into shell
CMD ["/bin/bash"]
